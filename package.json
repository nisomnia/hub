{
  "name": "hub",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "build": "vp run build",
    "dev": "vp run dev",
    "start": "vp run start",
    "prepare": "vp config",
    "ready": "vp check && vp run -r test && vp run -r build"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "zod": "^4.4.3"
  }
}
